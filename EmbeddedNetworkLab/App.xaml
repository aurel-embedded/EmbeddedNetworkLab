<Application x:Class="EmbeddedNetworkLab.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:EmbeddedNetworkLab"
             StartupUri="UI/Shell/MainWindow.xaml">
    <Application.Resources>
        <!-- Palette: dégradé de bleus -->
        <SolidColorBrush x:Key="PalettePrimary" Color="#083D77" />
        <SolidColorBrush x:Key="PaletteSecondary" Color="#2E85B7" />
        <SolidColorBrush x:Key="PaletteTertiary" Color="#6FB3E0" />
        <SolidColorBrush x:Key="PaletteQuaternary" Color="#E9F6FD" />
        <SolidColorBrush x:Key="PaletteQuinary" Color="#FFFFFF" />

        <!-- Primary brushes as dégradés -->
        <LinearGradientBrush x:Key="PrimaryBrush" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#0B4F8A" Offset="0" />
            <GradientStop Color="#2E85B7" Offset="1" />
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="PrimaryLightBrush" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#4FA7DE" Offset="0" />
            <GradientStop Color="#91D0F8" Offset="1" />
        </LinearGradientBrush>

        <SolidColorBrush x:Key="PrimaryDarkBrush" Color="#063859" />
        <SolidColorBrush x:Key="DisabledBrush" Color="#BFDDEE" />

        <!-- Navigation panel gradient (accentué, vertical) -->
        <LinearGradientBrush x:Key="NavBackgroundBrush" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#FF63B9FB" Offset="0" />
            <GradientStop Color="#FF0D173C" Offset="1" />
        </LinearGradientBrush>
        <SolidColorBrush x:Key="NavBorderBrush" Color="#9EDCF8" />
        
        <!-- Workspace subtle gradient (léger bleu) -->
        <LinearGradientBrush x:Key="WorkspaceBackgroundBrush" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#FFFFFF" Offset="0" />
            <GradientStop Color="#FFDAECFD" Offset="1" />
        </LinearGradientBrush>

        <!-- Accent brushes -->
        <SolidColorBrush x:Key="SuccessBrush" Color="#2E7D32" />
        <SolidColorBrush x:Key="ErrorBrush" Color="#D32F2F" />

        <!-- Global Button style / template -->
        <Style TargetType="Button">
            <Setter Property="Background" Value="{StaticResource PrimaryBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="4"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                              RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{StaticResource PrimaryLightBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{StaticResource PrimaryDarkBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Background" Value="{StaticResource DisabledBrush}"/>
                                <Setter Property="Foreground" Value="#EEEEEE"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Application.Resources>
</Application>
