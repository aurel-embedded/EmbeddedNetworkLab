<Window x:Class="EmbeddedNetworkLab.UI.Windows.VideoPlayerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vlc="clr-namespace:LibVLCSharp.WPF;assembly=LibVLCSharp.WPF"
        Title="Video Player" Height="480" Width="720"
        WindowStartupLocation="CenterOwner"
        Closing="Window_Closing">

    <Grid Background="#1E1E1E">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <vlc:VideoView x:Name="VideoView" Grid.Row="0" />

        <StackPanel Grid.Row="1" Orientation="Vertical" Background="#2D2D2D">
            <Slider x:Name="ProgressSlider"
                    Margin="10,8,10,4"
                    Minimum="0" Maximum="1" Value="0"
                    IsMoveToPointEnabled="True"
                    PreviewMouseDown="ProgressSlider_PreviewMouseDown"
                    PreviewMouseUp="ProgressSlider_PreviewMouseUp" />

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,4,0,8">
                <Button Content="&#9664;&#9664;" Width="36" Height="28" Margin="4,0"
                        ToolTip="Rewind 10s" Click="Rewind_Click" />
                <Button x:Name="PlayPauseButton" Content="&#9646;&#9646;" Width="48" Height="28" Margin="4,0"
                        Click="PlayPause_Click" />
                <Button Content="&#9654;&#9654;" Width="36" Height="28" Margin="4,0"
                        ToolTip="Forward 10s" Click="Forward_Click" />
                <Button Content="&#9632;" Width="36" Height="28" Margin="12,0,4,0"
                        ToolTip="Stop" Click="Stop_Click" />
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>
